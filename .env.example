# =============================================================================
# PointPilot — LLM configuration (Cursor Agent SDK)
# =============================================================================
# 1. Copy this file to `.env`            ->   cp .env.example .env
# 2. Paste your Cursor API key into CURSOR_API_KEY below.
# 3. Start BOTH processes together:      ->   npm run dev:all
#
# Architecture: the browser NEVER sees your Cursor key. The React app talks to a
# tiny local backend (server/index.mjs) which uses the Cursor Agent SDK
# (@cursor/sdk) with CURSOR_API_KEY to reach api.cursor.com — the same mechanism
# ~/ws/infra-ai uses, just the Node flavour.
# -----------------------------------------------------------------------------

# --- BACKEND (server-side only — the real secret) ---------------------------
# >>> PASTE YOUR CURSOR KEY HERE (starts with crsr_) <<<
# Get one at https://cursor.com/dashboard/integrations
CURSOR_API_KEY=

# Model the agent uses. "auto" lets Cursor pick a capable model.
# Other examples: claude-4-sonnet, claude-haiku-4-5, composer-2.5
CURSOR_MODEL=auto

# Port the PointPilot backend listens on.
PORT=8787

# --- FRONTEND (safe to expose; points the browser at the local backend) ------
VITE_LLM_BASE_URL=http://localhost:8787/v1
VITE_LLM_MODEL=auto
# Any non-empty value — real auth happens server-side via CURSOR_API_KEY.
VITE_LLM_API_KEY=local
